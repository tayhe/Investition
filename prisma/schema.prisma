generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User & Auth ──────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts  Account[]
  sessions  Session[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Brokerage Accounts ───────────────────────────────────────

model Account {
  id             String      @id @default(cuid())
  userId         String
  name           String      // e.g. "IBKR Main", "手动录入"
  broker         Broker      @default(MANUAL)
  currency       String      @default("USD") // account base currency
  ibkrFlexToken  String?     // IBKR Flex Web Service token
  ibkrFlexQueryId String?    // IBKR Flex Query ID
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions  Position[]
  trades     Trade[]

  @@index([userId])
}

enum Broker {
  IBKR
  MANUAL
}

// ─── Securities Master ────────────────────────────────────────

model Security {
  id          String       @id @default(cuid())
  symbol      String       // ticker: AAPL, 0700.HK, 600519.SS
  name        String       // display name
  exchange    String?      // NASDAQ, NYSE, SEHK, SSE, SZSE
  market      Market
  type        SecurityType @default(STOCK)
  currency    String       // trading currency
  isin        String?      // international identifier
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  positions Position[]
  trades    Trade[]
  prices    Price[]

  @@unique([symbol, exchange])
  @@index([market])
}

enum Market {
  US    // US stocks
  HK    // Hong Kong stocks
  A     // A-shares (Shanghai + Shenzhen)
  FUND  // Funds (any market)
}

enum SecurityType {
  STOCK
  ETF
  FUND
  BOND
  OPTION
  FUTURE
}

// ─── Positions (Current Holdings) ─────────────────────────────

model Position {
  id           String   @id @default(cuid())
  accountId    String
  securityId   String
  quantity     Decimal  @db.Decimal(18, 6) // shares/units held
  avgCost      Decimal  @db.Decimal(18, 6) // average cost per unit
  costBasis    Decimal  @db.Decimal(18, 4) // total cost in account currency
  currency     String   // position currency
  openedAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt

  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  security Security @relation(fields: [securityId], references: [id])

  @@unique([accountId, securityId])
  @@index([accountId])
}

// ─── Trade Records ────────────────────────────────────────────

model Trade {
  id            String      @id @default(cuid())
  accountId     String
  securityId    String
  orderId       String?     // broker order ID
  side          TradeSide
  quantity      Decimal     @db.Decimal(18, 6)
  price         Decimal     @db.Decimal(18, 6) // execution price
  amount        Decimal     @db.Decimal(18, 4) // quantity * price
  commission    Decimal?    @db.Decimal(18, 4)
  currency      String
  executedAt    DateTime    // trade execution time
  createdAt     DateTime    @default(now())

  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  security Security @relation(fields: [securityId], references: [id])

  @@index([accountId, executedAt])
  @@index([securityId])
}

enum TradeSide {
  BUY
  SELL
}

// ─── Daily Price Cache ────────────────────────────────────────

model Price {
  id         String   @id @default(cuid())
  securityId String
  date       DateTime @db.Date
  open       Decimal? @db.Decimal(18, 6)
  high       Decimal? @db.Decimal(18, 6)
  low        Decimal? @db.Decimal(18, 6)
  close      Decimal  @db.Decimal(18, 6)
  volume     BigInt?
  currency   String

  security Security @relation(fields: [securityId], references: [id])

  @@unique([securityId, date])
  @@index([securityId, date])
}

// ─── Portfolio Snapshots (for equity curve) ───────────────────

model Snapshot {
  id            String   @id @default(cuid())
  accountId     String
  date          DateTime @db.Date
  totalValue    Decimal  @db.Decimal(18, 4) // total portfolio value
  cashBalance   Decimal  @db.Decimal(18, 4) @default(0)
  positionsValue Decimal @db.Decimal(18, 4) // sum of position market values
  dailyPnl      Decimal? @db.Decimal(18, 4)
  dailyReturn   Decimal? @db.Decimal(18, 6) // percentage
  cumulativeReturn Decimal? @db.Decimal(18, 6)
  maxDrawdown   Decimal? @db.Decimal(18, 6) // max drawdown up to this date
  currency      String
  createdAt     DateTime @default(now())

  @@unique([accountId, date])
  @@index([accountId, date])
}

// ─── Exchange Rates (for multi-currency) ──────────────────────

model ExchangeRate {
  id          String   @id @default(cuid())
  baseCurrency String   // e.g. "USD"
  quoteCurrency String  // e.g. "CNY"
  rate        Decimal  @db.Decimal(18, 8)
  date        DateTime @db.Date
  createdAt   DateTime @default(now())

  @@unique([baseCurrency, quoteCurrency, date])
  @@index([date])
}
